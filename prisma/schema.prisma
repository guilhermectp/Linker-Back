generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum ClienteStatus {
  ATIVO
  INATIVO
  SUSPENSO
}

enum ConexaoStatus {
  ATIVO
  REDUZIDO
  BLOQUEADO
  CANCELADO
}

enum OrdemServicoTipo {
  INSTALACAO
  SUPORTE
  CANCELAMENTO
  TROCA_ENDERECO
}

enum OrdemServicoStatus {
  AGENDADA
  FINALIZADA
  CANCELADA
}

enum BoletoStatus {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

//////////////////////
// MODELS
//////////////////////

model Cliente {
  id               String @id @default(uuid())
  cpf              String           @unique
  nome             String
  email            String?          @unique
  telefone         String
  senhaCentralCliente     String
  status           ClienteStatus    @default(ATIVO)

  pontosConexao    PontoConexao[]
  boletos          Boleto[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  @@map("cliente")
}



model PontoConexao {
  id                 String @id @default(uuid())
  status             ConexaoStatus    @default(ATIVO)
  diaVencimento     Int            // dia do mês (ex: 10)
  dataUltimoPagamento DateTime?

  loginMk            String         @unique
  senhaMk            String

  tipoEndereco       String
  latitude           Float?
  longitude          Float?
  complemento        String?
  // urbano
  cep                String?
  cidade             String?
  bairro             String?
  rua                String?
  numero             String?
  //rural
  cidadeRefencia     String?
  nomeLocal          String?


  clienteId          String
  planoId            String

  cliente            Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  plano              Plano          @relation(fields: [planoId], references: [id])

  boletos            Boleto[]
  ordensServico      OrdemServico[]

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("pontoConexao")
}

model Plano {
  id            String @id @default(uuid())
  nome          String   @unique
  uploadMB      Int      // ex: 50, 100, 250
  downloadMB    Int      // ex: 50, 100, 250
  valor         Decimal  @db.Decimal(10,2)
  descricao     String?

  pontosConexao PontoConexao[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("plano")
}


model Boleto {
  id             String       @id @default(uuid())
  referente      String       // "Janeiro/2026"
  valor          Decimal      @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         BoletoStatus @default(PENDENTE)
  linkBoleto     String?
  clienteId      String
  pontoConexaoId String
  cliente        Cliente      @relation(fields: [clienteId], references: [id])
  pontoConexao   PontoConexao @relation(fields: [pontoConexaoId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("boleto")
}
model OrdemServico {
  id             String             @id @default(uuid())
  tipo           OrdemServicoTipo
  status         OrdemServicoStatus @default(AGENDADA)
  dataAgendada   DateTime
  observacao     String?
  pontoConexaoId String
  pontoConexao   PontoConexao       @relation(fields: [pontoConexaoId], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("ordemServico")
}