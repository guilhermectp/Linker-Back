generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum ClienteStatus {
  ATIVO
  DESATIVADO
}

enum ConexaoStatus {
  ATIVO
  REDUZIDO
  BLOQUEADO
  CANCELADO
}

enum BoletoStatus {
  PAGO
  PENDENTE
  ATRASADO
  CANCELADO
}

enum SuporteStatus {
  EM_ABERTO
  EM_ANDAMENTO
  CANCELADO
  FINALIZADO
}

//////////////////////
// MODELS
//////////////////////

model Cliente {
  id               String @id @default(uuid())
  cpf              String           @unique
  nome             String
  email            String?          @unique
  telefone         String
  senhaCentralCliente     String
  status           ClienteStatus    @default(ATIVO)

  pontosConexao    PontoConexao[]
  boletos          Boleto[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  @@map("cliente")
}



model PontoConexao {
  id                 String @id @default(uuid())
  status             ConexaoStatus    @default(ATIVO)
  diaVencimento     Int            // dia do mês (ex: 10)
  dataUltimoPagamento DateTime?

  loginMk            String         @unique
  senhaMk            String

  tipoEndereco       String
  latitude           Float?
  longitude          Float?
  complemento        String?
  // urbano
  cep                String?
  cidade             String?
  bairro             String?
  rua                String?
  numero             String?
  //rural
  cidadeRefencia     String?
  nomeLocal          String?


  clienteId          String
  planoId            String

  cliente            Cliente        @relation(fields: [clienteId], references: [id])
  plano              Plano          @relation(fields: [planoId], references: [id])

  boletos            Boleto[]
  suportes           Suporte[]

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("pontoConexao")
}

model Plano {
  id            String @id @default(uuid())
  nome          String   @unique
  uploadMB      Int      // ex: 50, 100, 250
  downloadMB    Int      // ex: 50, 100, 250
  valor         Decimal  @db.Decimal(10,2)
  descricao     String?

  pontosConexao PontoConexao[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("plano")
}


model Boleto {
  id               String @id @default(uuid())
  valor            Decimal       @db.Decimal(10,2)
  dataVencimento   DateTime
  dataPagamento    DateTime?
  status           BoletoStatus  @default(PENDENTE)
  linkBoleto       String?

  clienteId        String
  pontoConexaoId   String

  cliente          Cliente       @relation(fields: [clienteId], references: [id])
  pontoConexao     PontoConexao  @relation(fields: [pontoConexaoId], references: [id])

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  @@map("boleto")
}

model Suporte {
  id               String @id @default(uuid())
  assunto          String
  descricao        String
  status           SuporteStatus  @default(EM_ABERTO)

  pontoConexaoId   String            
  pontoConexao     PontoConexao   @relation(fields: [pontoConexaoId], references: [id])

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("suporte")
}